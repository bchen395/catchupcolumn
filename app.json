{
  "expo": {
    "name": "Catch Up Column",
    "slug": "catch-up-column",
    "version": "1.0.0",
    "description": "A private weekly newsletter you write together with family and friends. Share short updates throughout the week — and on publish day, everything gets compiled into a beautifully formatted edition delivered to your group.",
    "primaryColor": "#1A1A1A",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "catchupcolumn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF9F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.catchupcolumn.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.catchupcolumn.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FBF9F4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Catch Up Column needs access to your photos so you can add a picture to your post."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#E8442E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c9be4074-4916-4e94-9276-811bbe8a05dc"
      }
    },
    "owner": "bchen395"
  }
}
